Host kans-mac-mini kans-air-m5 kans-macbook *.ts.net 100.*
	ProxyCommand none
	ProxyJump none

Host kans-mac-mini
	HostName kans-mac-mini
	ForwardAgent yes
	User kan
	# 心跳保活：每 15s 发探测，连续 6 次（~90s）无响应才判定断线，
	# 让短暂网络抖动不被当成断线，少触发 VS Code Remote 的重连/reload
	ServerAliveInterval 15
	ServerAliveCountMax 6

Host github.com kanlacgit
	HostName ssh.github.com
	Port 443
	User git
	IdentityFile ~/.ssh/kanlac_git
	IdentitiesOnly yes
	# Test: ssh -T git@github.com
  ProxyCommand bash -c '[ -n "$all_proxy" ] && exec nc -X 5 -x "${all_proxy#socks5://}" %h %p || exec nc %h %p'

Host mindfitgit
	HostName github.com
	User git
	IdentityFile ~/.ssh/mindfit_git
	IdentitiesOnly yes

Host autodl
    HostName connect.bjb1.seetacloud.com
    Port 34265
    User root
    StrictHostKeyChecking no
    ControlMaster auto
    ControlPath /tmp/ssh-autodl-%r@%h:%p
    ControlPersist 600
