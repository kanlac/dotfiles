Host kans-mac-mini
	HostName kans-mac-mini
	ForwardAgent yes
	User kan

Host github.com kanlacgit
	HostName ssh.github.com
	Port 443
	User git
	IdentityFile ~/.ssh/kanlac_git
	IdentitiesOnly yes
	# Test: ssh -T git@github.com
  ProxyCommand bash -c '[ -n "$all_proxy" ] && exec nc -X 5 -x "${all_proxy#socks5://}" %h %p || exec nc %h %p'

Host mindfitgit
	HostName github.com
	User git
	IdentityFile ~/.ssh/mindfit_git
	IdentitiesOnly yes
