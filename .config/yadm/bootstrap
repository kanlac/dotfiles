#!/bin/bash
set -e

# yadm Bootstrap Script
# This script automatically installs oh-my-zsh plugins and tools when setting up on a new machine

echo "Running yadm bootstrap script..."

# Detect OS
OS="$(uname -s)"

# Install Homebrew packages
if [[ "$OS" == "Darwin" ]]; then
    echo "Installing Homebrew packages..."

    # Check if Homebrew is installed
    if ! command -v brew &> /dev/null; then
        echo "Homebrew not found. Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    # Install zoxide if not already installed
    if ! command -v zoxide &> /dev/null; then
        echo "Installing zoxide..."
        brew install zoxide
    fi

    # Install Neovim if not already installed
    if ! command -v nvim &> /dev/null; then
        echo "Installing Neovim..."
        brew install neovim
    fi

    # Install im-select for input method switching (macOS only)
    if ! command -v im-select &> /dev/null; then
        echo "Installing im-select..."
        brew tap daipeihust/tap
        brew install im-select
    fi

    # Install jq for JSON processing
    if ! command -v jq &> /dev/null; then
        echo "Installing jq..."
        brew install jq
    fi

    # Install fzf (fuzzy finder)
    if ! command -v fzf &> /dev/null; then
        echo "Installing fzf..."
        brew install fzf
    fi
    # Ensure fzf shell integration is installed
    if [ ! -f "$HOME/.fzf.zsh" ]; then
        echo "Installing fzf shell integration..."
        $(brew --prefix)/opt/fzf/install --all --no-bash --no-fish
    fi

    # Install ripgrep (fast text search)
    if ! command -v rg &> /dev/null; then
        echo "Installing ripgrep..."
        brew install ripgrep
    fi

    # Install fd (fast file finder)
    if ! command -v fd &> /dev/null; then
        echo "Installing fd..."
        brew install fd
    fi

    # Install Ghostty terminal
    if ! command -v ghostty &> /dev/null; then
        echo "Installing Ghostty..."
        brew install --cask ghostty
    fi
fi

# Install oh-my-zsh if not already installed
if [ ! -d "$HOME/.oh-my-zsh" ]; then
    echo "Installing oh-my-zsh..."
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
fi

# Install zsh-autosuggestions plugin
# Note: Don't source .zshrc here as it contains zsh-specific syntax
ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
if [ ! -d "$ZSH_CUSTOM/plugins/zsh-autosuggestions" ]; then
    echo "Installing zsh-autosuggestions..."
    git clone https://github.com/zsh-users/zsh-autosuggestions "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
else
    echo "zsh-autosuggestions already installed"
fi

# Install zsh-syntax-highlighting plugin
if [ ! -d "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting" ]; then
    echo "Installing zsh-syntax-highlighting..."
    git clone https://github.com/zsh-users/zsh-syntax-highlighting "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"
else
    echo "zsh-syntax-highlighting already installed"
fi


# ===== Coding Agents Configuration =====
CONFIG_SOURCE="$HOME/.config/agents.json"

if [ -f "$CONFIG_SOURCE" ] && command -v jq &> /dev/null; then
    echo "Applying coding agents configuration..."

    # ----- Claude: Merge MCP servers -----
    CLAUDE_JSON="$HOME/.claude.json"
    if [ -f "$CLAUDE_JSON" ]; then
        jq --slurpfile src "$CONFIG_SOURCE" \
          '.mcpServers = (.mcpServers // {}) * $src[0].claude.mcpServers' \
          "$CLAUDE_JSON" > /tmp/claude.json.tmp && mv /tmp/claude.json.tmp "$CLAUDE_JSON"
    else
        jq '{mcpServers: .claude.mcpServers}' "$CONFIG_SOURCE" > "$CLAUDE_JSON"
    fi
    echo "  Claude MCP servers merged"

    # ----- OpenCode: Merge MCP servers -----
    OPENCODE_JSON="$HOME/.config/opencode/opencode.json"
    if [ -f "$OPENCODE_JSON" ]; then
        jq --slurpfile src "$CONFIG_SOURCE" \
          '.mcp = (.mcp // {}) * $src[0].opencode.mcp' \
          "$OPENCODE_JSON" > /tmp/opencode.json.tmp && mv /tmp/opencode.json.tmp "$OPENCODE_JSON"
        echo "  OpenCode MCP servers merged"
    fi

    # ----- Claude: Merge hooks to settings.json -----
    CLAUDE_SETTINGS="$HOME/.claude/settings.json"
    if [ -f "$CLAUDE_SETTINGS" ]; then
        jq --slurpfile src "$CONFIG_SOURCE" '
          .hooks = (.hooks // {}) * $src[0].claude.hooks
        ' "$CLAUDE_SETTINGS" > /tmp/settings.json.tmp && mv /tmp/settings.json.tmp "$CLAUDE_SETTINGS"
    else
        mkdir -p "$HOME/.claude"
        jq '{
          hooks: .claude.hooks
        }' "$CONFIG_SOURCE" > "$CLAUDE_SETTINGS"
    fi
    echo "  Claude hooks merged"

    # ----- Codex: Export config to TOML -----
    if jq -e '.codex.config' "$CONFIG_SOURCE" &> /dev/null; then
        echo "Syncing Codex configuration..."

        # Ensure Python dependencies are installed
        if ! python3 -c "import tomlkit" 2>/dev/null; then
            echo "  Installing required Python packages..."
            pip3 install tomlkit --quiet --user --break-system-packages 2>/dev/null || \
            pip3 install tomlkit --quiet --user
        fi

        # Run Python script to sync config
        python3 "$HOME/.config/yadm/scripts/sync-codex-config.py"
    fi

    # ----- Execute commands -----
    echo "Executing commands..."
    jq -r '.commands[]' "$CONFIG_SOURCE" | while read cmd; do
        echo "  Running: $cmd"
        eval "$cmd" 2>/dev/null || true
    done
fi

# ===== Generate Clash Verge Script from template =====
CLASH_SCRIPT_TPL="$HOME/.config/clash-verge/Script.js.tpl"
CLASH_SCRIPT_OUT="$HOME/Library/Application Support/io.github.clash-verge-rev.clash-verge-rev/profiles/Script.js"

if [ -f "$CLASH_SCRIPT_TPL" ]; then
    # Load .env to get self-hosted proxy variables
    [ -f "$HOME/.env" ] && source "$HOME/.env"

    NODE_CDN_DOMAIN="${NODE_CDN_DOMAIN:-kanlac.store}"
    NODE_CDN_SERVER="${NODE_CDN_SERVER:-$NODE_CDN_DOMAIN}"

    if [ -n "$NODE_SERVER" ] && [ -n "$NODE_UUID" ] && \
       [ -n "$NODE_REALITY_PUBLIC_KEY" ] && [ -n "$NODE_REALITY_SHORT_ID" ]; then
        mkdir -p "$(dirname "$CLASH_SCRIPT_OUT")"
        CLASH_SCRIPT_TMP="$(mktemp)"
        sed -e "s|__NODE_SERVER__|$NODE_SERVER|g" \
            -e "s|__NODE_UUID__|$NODE_UUID|g" \
            -e "s|__NODE_REALITY_PUBLIC_KEY__|$NODE_REALITY_PUBLIC_KEY|g" \
            -e "s|__NODE_REALITY_SHORT_ID__|$NODE_REALITY_SHORT_ID|g" \
            -e "s|__NODE_CDN_SERVER__|$NODE_CDN_SERVER|g" \
            -e "s|__NODE_CDN_DOMAIN__|$NODE_CDN_DOMAIN|g" \
            "$CLASH_SCRIPT_TPL" > "$CLASH_SCRIPT_TMP"
        cp "$CLASH_SCRIPT_TMP" "$CLASH_SCRIPT_OUT"

        # Clash Verge stores each profile's active script under a generated uid.
        # Keep the stable Script.js and the current profile's bound script in sync.
        CLASH_PROFILES_YAML="$(dirname "$CLASH_SCRIPT_OUT")/../profiles.yaml"
        CLASH_PROFILES_DIR="$(dirname "$CLASH_SCRIPT_OUT")"
        CLASH_SCRIPT_TMP="$CLASH_SCRIPT_TMP" \
        CLASH_PROFILES_YAML="$CLASH_PROFILES_YAML" \
        CLASH_PROFILES_DIR="$CLASH_PROFILES_DIR" \
        python3 <<'PY' || true
import os
import shutil
from pathlib import Path

profiles_yaml = Path(os.environ["CLASH_PROFILES_YAML"])
profiles_dir = Path(os.environ["CLASH_PROFILES_DIR"])
script_tmp = Path(os.environ["CLASH_SCRIPT_TMP"])

if not profiles_yaml.exists():
    raise SystemExit(0)

current = None
items = []
item = None
for raw in profiles_yaml.read_text().splitlines():
    line = raw.strip()
    if raw.startswith("current: "):
        current = line.split(":", 1)[1].strip()
    elif raw.startswith("- uid: "):
        if item:
            items.append(item)
        item = {"uid": line.split(":", 1)[1].strip()}
    elif item is not None:
        if raw.startswith("  type: "):
            item["type"] = line.split(":", 1)[1].strip()
        elif raw.startswith("  file: "):
            item["file"] = line.split(":", 1)[1].strip()
        elif raw.startswith("    script: "):
            item["option_script"] = line.split(":", 1)[1].strip()
if item:
    items.append(item)

current_item = next((entry for entry in items if entry.get("uid") == current), None)
script_uid = (current_item or {}).get("option_script")
script_item = next((entry for entry in items if entry.get("uid") == script_uid), None)
script_file = (script_item or {}).get("file")
if script_item and script_item.get("type") == "script" and script_file:
    target = profiles_dir / script_file
    shutil.copyfile(script_tmp, target)
    print(f"Clash Verge active profile script synced: {target}")
PY
        rm -f "$CLASH_SCRIPT_TMP"
        echo "Clash Verge Script.js generated"
    else
        echo "Warning: self-hosted proxy variables not set in ~/.env, skipping Script.js generation"
    fi
fi

echo ""
echo "Bootstrap complete! Restart your shell to apply changes."
echo ""
echo "Don't forget to:"
echo "  1. Create ~/.env file with your sensitive environment variables"
echo "     (NODE_SERVER, NODE_UUID, NODE_REALITY_PUBLIC_KEY, NODE_REALITY_SHORT_ID)"
echo "     Optional: NODE_CDN_SERVER, NODE_CDN_DOMAIN"
echo "  2. Open Neovim to let lazy.nvim install plugins: nvim"
